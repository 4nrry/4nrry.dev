---
import { resolveLocale, ui } from '../i18n/ui';
const t = ui[resolveLocale(Astro.currentLocale)].rhythm;
---

<section id="section-rhythm" class="mx-auto max-w-5xl px-6 py-14 sm:py-16">
  <p class="eyebrow">rhythm</p>
  <h2 class="mt-2 font-mono text-2xl sm:text-3xl font-bold">{t.title}</h2>
  <p class="mt-3 max-w-2xl text-muted">{t.intro}</p>
  <div class="overflow-x-auto pb-2">
    <canvas id="viz-weekday" class="shimmer mt-8 w-full min-w-[640px] rounded-md"></canvas>
  </div>
</section>
