---
import { resolveLocale, ui } from '../i18n/ui';
const t = ui[resolveLocale(Astro.currentLocale)].systems;
---

<section id="section-systems" class="mx-auto max-w-5xl px-6 py-14 sm:py-16">
  <p class="eyebrow">systems</p>
  <h2 class="mt-2 font-mono text-2xl sm:text-3xl font-bold">{t.title}</h2>
  <p class="mt-3 max-w-2xl text-muted">{t.intro}</p>

  <!-- Case: OpenCherry -->
  <article class="card mt-8 p-6 sm:p-8">
    <header class="flex flex-wrap items-baseline justify-between gap-2">
      <h3 class="font-mono text-lg font-bold text-accent-bright">{t.oc.title}</h3>
      <p class="font-mono text-xs text-faint">
        {t.oc.meta}
        <a class="underline underline-offset-2 hover:text-muted" href="https://opencherry.dev" rel="noopener">opencherry.dev</a>
      </p>
    </header>

    <div class="mt-6 grid gap-x-8 gap-y-4 text-sm leading-relaxed text-muted sm:grid-cols-2">
      <p><span class="font-mono text-xs text-accent">{t.need}</span><br />{t.oc.need}</p>
      <p><span class="font-mono text-xs text-accent">{t.decisions}</span><br />{t.oc.decisions}</p>
      <p><span class="font-mono text-xs text-accent">{t.tradeoffs}</span><br />{t.oc.tradeoffs}</p>
      <p>
        <span class="font-mono text-xs text-accent">{t.outcome}</span><br />
        {t.oc.outcome}
        <a class="underline underline-offset-2 hover:text-text" href="https://github.com/4nrry/opencherry" rel="noopener">github.com/4nrry/opencherry</a>.
      </p>
    </div>

    <figure class="mt-8">
      <div class="overflow-x-auto">
        <svg viewBox="0 0 640 240" class="w-full min-w-[560px]" role="img" aria-label={t.oc.aria}>
          <g font-family="JetBrains Mono, monospace" font-size="11">
            <rect x="8" y="88" width="110" height="64" rx="6" fill="#18181b" stroke="#27272a"/>
            <text x="63" y="115" text-anchor="middle" fill="#fafafa">SolidJS UI</text>
            <text x="63" y="132" text-anchor="middle" fill="#52525b" font-size="9">WebView</text>

            <rect x="180" y="28" width="250" height="184" rx="6" fill="#101013" stroke="#d97706"/>
            <text x="196" y="50" fill="#d97706" font-size="10">Rust core</text>
            <rect x="200" y="60" width="210" height="26" rx="4" fill="#18181b" stroke="#27272a"/>
            <text x="305" y="77" text-anchor="middle" fill="#fafafa" font-size="10">shared types</text>
            <rect x="200" y="96" width="210" height="26" rx="4" fill="#18181b" stroke="#27272a"/>
            <text x="305" y="113" text-anchor="middle" fill="#fafafa" font-size="10">git (embedded libgit2)</text>
            <rect x="200" y="132" width="210" height="26" rx="4" fill="#18181b" stroke="#27272a"/>
            <text x="305" y="149" text-anchor="middle" fill="#fafafa" font-size="10">agent detect (sysinfo)</text>
            <rect x="200" y="168" width="210" height="26" rx="4" fill="#18181b" stroke="#27272a"/>
            <text x="305" y="185" text-anchor="middle" fill="#fafafa" font-size="10">SQLite persistence</text>

            <rect x="476" y="56" width="152" height="40" rx="6" fill="#18181b" stroke="#27272a"/>
            <text x="552" y="74" text-anchor="middle" fill="#fafafa">git CLI</text>
            <text x="552" y="89" text-anchor="middle" fill="#52525b" font-size="9">remote ops only</text>

            <rect x="476" y="110" width="152" height="40" rx="6" fill="#18181b" stroke="#27272a"/>
            <text x="552" y="128" text-anchor="middle" fill="#fafafa">process table</text>
            <text x="552" y="143" text-anchor="middle" fill="#52525b" font-size="9">read, never spawn</text>

            <rect x="476" y="164" width="152" height="40" rx="6" fill="#18181b" stroke="#27272a"/>
            <text x="552" y="182" text-anchor="middle" fill="#fafafa">opencherry.db</text>
            <text x="552" y="197" text-anchor="middle" fill="#52525b" font-size="9">local state</text>

            <g stroke="#52525b" stroke-width="1.5" fill="none">
              <path d="M118 120 H176"/>
              <path d="M430 109 L472 76"/>
              <path d="M430 145 L472 130"/>
              <path d="M430 181 L472 184"/>
            </g>
            <g fill="#52525b">
              <path d="M176 116 l8 4 -8 4 z"/>
              <path d="M472 72 l8 4 -6 6 z"/>
              <path d="M472 126 l8 4 -7 5 z"/>
              <path d="M472 180 l8 4 -8 4 z"/>
            </g>
            <text x="147" y="110" text-anchor="middle" fill="#52525b" font-size="9">Tauri IPC</text>
          </g>
        </svg>
      </div>
      <figcaption class="mt-1 font-mono text-[0.65rem] text-faint">{t.oc.figcaption}</figcaption>
    </figure>
  </article>

  <!-- Case: this site -->
  <article class="card mt-6 p-6 sm:p-8">
    <header class="flex flex-wrap items-baseline justify-between gap-2">
      <h3 class="font-mono text-lg font-bold text-accent-bright">{t.site.title}</h3>
      <p class="font-mono text-xs text-faint">
        {t.site.metaAuditable}
        <a class="underline underline-offset-2 hover:text-muted" href="https://github.com/4nrry/4nrry.dev" rel="noopener">{t.site.metaSource}</a>
      </p>
    </header>

    <div class="mt-6 grid gap-x-8 gap-y-4 text-sm leading-relaxed text-muted sm:grid-cols-2">
      <p><span class="font-mono text-xs text-accent">{t.need}</span><br />{t.site.need}</p>
      <p><span class="font-mono text-xs text-accent">{t.decisions}</span><br />{t.site.decisions}</p>
      <p><span class="font-mono text-xs text-accent">{t.tradeoffs}</span><br />{t.site.tradeoffs}</p>
      <p>
        <span class="font-mono text-xs text-accent">{t.outcome}</span><br />
        {t.site.outcomeBefore}<a class="underline underline-offset-2 hover:text-text" href="/api/portfolio.json">/api/portfolio.json</a>{t.site.outcomeAfter}
      </p>
    </div>

    <figure class="mt-8">
      <div class="overflow-x-auto">
        <svg viewBox="0 0 640 210" class="w-full min-w-[560px]" role="img" aria-label={t.site.aria}>
          <g font-family="JetBrains Mono, monospace" font-size="11">
            <rect x="8" y="20" width="110" height="40" rx="6" fill="#18181b" stroke="#27272a"/>
            <text x="63" y="44" text-anchor="middle" fill="#fafafa">GitHub API</text>

            <rect x="160" y="8" width="330" height="64" rx="6" fill="#101013" stroke="#d97706"/>
            <text x="176" y="28" fill="#d97706" font-size="10">sync (cron, every 6h)</text>
            <rect x="176" y="36" width="86" height="26" rx="4" fill="#18181b" stroke="#27272a"/>
            <text x="219" y="53" text-anchor="middle" fill="#fafafa" font-size="10">allowlist</text>
            <rect x="272" y="36" width="90" height="26" rx="4" fill="#18181b" stroke="#27272a"/>
            <text x="317" y="53" text-anchor="middle" fill="#fafafa" font-size="10">aggregate</text>
            <rect x="372" y="36" width="102" height="26" rx="4" fill="#18181b" stroke="#d97706"/>
            <text x="423" y="53" text-anchor="middle" fill="#fafafa" font-size="10">sanitize gate</text>

            <rect x="530" y="20" width="102" height="40" rx="6" fill="#18181b" stroke="#27272a"/>
            <text x="581" y="38" text-anchor="middle" fill="#fafafa">KV</text>
            <text x="581" y="53" text-anchor="middle" fill="#52525b" font-size="9">one JSON doc</text>

            <rect x="530" y="130" width="102" height="40" rx="6" fill="#18181b" stroke="#27272a"/>
            <text x="581" y="148" text-anchor="middle" fill="#fafafa">/api/*.json</text>
            <text x="581" y="163" text-anchor="middle" fill="#52525b" font-size="9">ETag + SWR</text>

            <rect x="300" y="130" width="130" height="40" rx="6" fill="#18181b" stroke="#27272a"/>
            <text x="365" y="154" text-anchor="middle" fill="#fafafa">this page</text>

            <g stroke="#52525b" stroke-width="1.5" fill="none">
              <path d="M118 40 H156"/>
              <path d="M262 49 H268"/>
              <path d="M362 49 H368"/>
              <path d="M490 40 H526"/>
              <path d="M581 60 V126"/>
              <path d="M526 150 H434"/>
            </g>
            <g fill="#52525b">
              <path d="M156 36 l8 4 -8 4 z"/>
              <path d="M526 36 l8 4 -8 4 z"/>
              <path d="M577 126 l4 8 4 -8 z"/>
              <path d="M434 146 l-8 4 8 4 z"/>
            </g>
            <text x="176" y="92" fill="#52525b" font-size="10">violation = no publish, the last good dataset keeps serving</text>
          </g>
        </svg>
      </div>
      <figcaption class="mt-1 font-mono text-[0.65rem] text-faint">{t.site.figcaption}</figcaption>
    </figure>
  </article>

  <p class="mt-6 font-mono text-xs text-faint">{t.more}</p>
</section>
