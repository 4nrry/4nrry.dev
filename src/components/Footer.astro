---
import { resolveLocale, ui } from '../i18n/ui';
import LangToggle from './LangToggle.astro';
const t = ui[resolveLocale(Astro.currentLocale)].contact;
---

<footer id="contact" class="mx-auto max-w-5xl px-6 pb-20 pt-14 sm:pt-16">
  <p class="eyebrow">contact</p>
  <h2 class="mt-2 font-mono text-2xl sm:text-3xl font-bold">{t.title}</h2>
  <p class="mt-3 max-w-2xl text-muted">{t.intro}</p>
  <div class="mt-6 flex flex-wrap gap-4 font-mono text-sm">
    <a
      class="rounded border border-border px-3 py-1.5 text-muted transition-colors hover:border-accent hover:text-accent-bright"
      href="mailto:anrry.petrin@hotmail.com">anrry.petrin@hotmail.com</a
    >
    <a
      class="rounded border border-border px-3 py-1.5 text-muted transition-colors hover:border-accent hover:text-accent-bright"
      href="https://github.com/4nrry"
      rel="noopener">github.com/4nrry</a
    >
  </div>
  <div class="mt-12 flex flex-wrap items-start justify-between gap-4 border-t border-border pt-6">
    <p class="max-w-2xl font-mono text-xs leading-relaxed text-faint">
      {t.noteBefore}
      <a class="underline underline-offset-2 hover:text-muted" href="https://github.com/4nrry/4nrry.dev" rel="noopener">{t.noteSource}</a>
      {t.noteInspired}
      <a class="underline underline-offset-2 hover:text-muted" href="https://github.com/akitaonrails/github-visualize" rel="noopener">akitaonrails/github-visualize</a>.
    </p>
    <LangToggle />
  </div>
</footer>
