---
import { resolveLocale, ui } from '../i18n/ui';
const t = ui[resolveLocale(Astro.currentLocale)].languages;
---

<section id="section-languages" class="mx-auto max-w-5xl px-6 py-14 sm:py-16">
  <p class="eyebrow">languages</p>
  <h2 class="mt-2 font-mono text-2xl sm:text-3xl font-bold">{t.title}</h2>
  <p class="mt-3 max-w-2xl text-muted">{t.intro}</p>
  <canvas id="viz-languages" class="shimmer mt-8 w-full rounded-md"></canvas>
  <ul id="languages-list" class="mt-4 flex flex-wrap gap-x-5 gap-y-2"></ul>
</section>
