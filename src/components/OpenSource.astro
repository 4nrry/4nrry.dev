---
import { resolveLocale, ui } from '../i18n/ui';
const t = ui[resolveLocale(Astro.currentLocale)].oss;
---

<section id="section-oss" class="mx-auto max-w-5xl px-6 py-14 sm:py-16">
  <p class="eyebrow">open-source</p>
  <h2 class="mt-2 font-mono text-2xl sm:text-3xl font-bold">{t.title}</h2>
  <p class="mt-3 max-w-2xl text-muted">{t.intro}</p>
  <div id="oss-grid" class="mt-8 grid gap-4 md:grid-cols-2">
    <div class="card shimmer h-48"></div>
    <div class="card shimmer h-48"></div>
    <div class="card shimmer h-48"></div>
    <div class="card shimmer h-48"></div>
    <div class="card shimmer h-48"></div>
  </div>
</section>
