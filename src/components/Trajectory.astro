---
import { resolveLocale, ui } from '../i18n/ui';
const t = ui[resolveLocale(Astro.currentLocale)].trajectory;
---

<section id="section-trajectory" class="mx-auto max-w-5xl px-6 py-14 sm:py-16">
  <p class="eyebrow">trajectory</p>
  <h2 class="mt-2 font-mono text-2xl sm:text-3xl font-bold">{t.title}</h2>
  <ol class="mt-8 flex max-w-2xl flex-col">
    {
      t.chapters.map((chapter, i) => (
        <li class="relative border-l border-border pb-10 pl-8 last:pb-0">
          <span class="absolute -left-[13px] top-0 rounded bg-bg px-1 font-mono text-xs font-bold text-accent">
            {String(i + 1).padStart(2, '0')}
          </span>
          <h3 class="font-mono text-base font-bold">{chapter.title}</h3>
          <p class="mt-1.5 text-sm leading-relaxed text-muted">{chapter.body}</p>
        </li>
      ))
    }
  </ol>
</section>
